Algoritmo Calculadora
	Escribir "Escribe el primer número: "
	Leer N
	Escribir "Escribe el segundo número: "
	Leer P
	S = N + P
	R = N - P
	M = N * P
	D = N / P
	Escribir N, " + ",P " = ",S
	Escribir N, " - ",P " = ",R
	Escribir N, " * ",P " = ",M
	Escribir N, " / ",P " = ",D
FinAlgoritmo
